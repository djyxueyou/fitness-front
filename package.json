{
  "name": "fitforge-uni-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev:custom": "uni -p",
    "dev:h5": "uni",
    "dev:mp-weixin": "uni -p mp-weixin --mode mp-weixin",
    "build:h5": "uni build",
    "build:mp-weixin": "uni build -p mp-weixin --mode mp-weixin && node scripts/sync-mp-weixin-appid.mjs",
    "build:app-plus": "uni build -p app-plus",
    "format": "prettier --write \"src/**/*.{vue,ts,js,scss,json}\" \"*.{ts,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{vue,ts,js,scss,json}\" \"*.{ts,js,json}\""
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-5000720260410001",
    "@dcloudio/uni-app-plus": "3.0.0-5000720260410001",
    "@dcloudio/uni-components": "3.0.0-5000720260410001",
    "@dcloudio/uni-h5": "3.0.0-5000720260410001",
    "@dcloudio/uni-mp-weixin": "3.0.0-5000720260410001",
    "pinia": "^2.3.1",
    "sass": "^1.89.0",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.8",
    "@dcloudio/uni-cli-shared": "3.0.0-5000720260410001",
    "@dcloudio/vite-plugin-uni": "3.0.0-5000720260410001",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "vite": "5.2.8"
  }
}
